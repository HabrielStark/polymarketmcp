# Hermes-PM — example environment configuration
#
# Every variable here is OPTIONAL; the listed value is the built-in default.
# All settings use the HPM_ prefix and are read from the process environment
# (see src/hermes_pm/config.py::Settings).
#
# This file is a reference template, NOT auto-loaded by the app. Apply it by
# exporting the variables into your environment, e.g.:
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#   bash/zsh:    set -a && source .env && set +a
#   or run via:  dotenv run -- hermes-pm-demo   (python-dotenv is installed)
#
# NEVER commit a real .env. Secrets must use placeholders here only.

# ----------------------------------------------------------------------------
# Storage (local SQLite ledger + hash-chained audit log)
# ----------------------------------------------------------------------------
HPM_DATA_DIR=./.hermes_pm_data
HPM_DB_FILENAME=hermes_pm.sqlite3

# ----------------------------------------------------------------------------
# Market-data source
#   synthetic = offline, deterministic (default; best for tests/demo)
#   replay    = deterministic playback of a recorded snapshot file
#   live      = Polymarket (read-only data; live ORDERS remain locked)
# ----------------------------------------------------------------------------
HPM_MARKET_DATA_SOURCE=synthetic
HPM_SYNTHETIC_SEED=1337
HPM_SYNTHETIC_MARKET_COUNT=6
# HPM_REPLAY_FILE=./recordings/session.jsonl

# Polymarket endpoints (used only when HPM_MARKET_DATA_SOURCE=live)
HPM_GAMMA_BASE_URL=https://gamma-api.polymarket.com
HPM_CLOB_BASE_URL=https://clob.polymarket.com
HPM_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
HPM_GEOBLOCK_URL=https://polymarket.com/api/geoblock

# ----------------------------------------------------------------------------
# Reliability / staleness
# ----------------------------------------------------------------------------
HPM_WS_RECONNECT_STALE_MS=5000
HPM_RECONCILE_INTERVAL_MS=10000

# ----------------------------------------------------------------------------
# Dashboard (FastAPI). Binds localhost by default. A token is REQUIRED for all
# REST + /metrics + /ws endpoints whenever the host is not 127.0.0.1.
# ----------------------------------------------------------------------------
HPM_DASHBOARD_HOST=127.0.0.1
HPM_DASHBOARD_PORT=8787
# HPM_DASHBOARD_TOKEN=replace-with-a-long-random-token

# ----------------------------------------------------------------------------
# MCP Streamable HTTP transport (OFF by default; stdio is the primary transport).
# When enabled, Origin/Host DNS-rebinding protection + bearer token are enforced.
# ----------------------------------------------------------------------------
HPM_MCP_HTTP_ENABLED=false
HPM_MCP_HTTP_HOST=127.0.0.1
HPM_MCP_HTTP_PORT=8989
# HPM_MCP_HTTP_TOKEN=replace-with-a-long-random-token

# ----------------------------------------------------------------------------
# Live execution boundary — LOCKED BY DEFAULT.
# Setting HPM_LIVE_ENABLED=true is NOT sufficient on its own: EVERY gate below
# must independently pass, the geoblock check must succeed (fail-closed), and a
# signing key must be present in the configured secret store. The live tool is
# reference-only and cannot be triggered through raw MCP arguments.
# ----------------------------------------------------------------------------
HPM_LIVE_ENABLED=false
HPM_OPERATOR_AGE_VERIFIED=false
HPM_OPERATOR_JURISDICTION_ALLOWED=false
HPM_OPERATOR_ACKNOWLEDGED_RISK=false
HPM_OPERATOR_PLATFORM_TERMS_ACCEPTED=false
HPM_OPERATOR_NO_BYPASS_TOOLS=false
HPM_OPERATOR_NO_MARKET_MANIPULATION=false
HPM_RED_TEAM_PASSED=false
# Run the locked live adapter in its own OS process (NFR-SEC-007).
HPM_LIVE_PROCESS_ISOLATION=false

# ----------------------------------------------------------------------------
# Secret storage (NFR-SEC-001)
#   env            = read HPM_SECRET_<NAME> env vars (default; paper needs none)
#   encrypted_file = Fernet-encrypted file at rest, key derived from passphrase
#   keyring        = OS keychain (requires the optional "keyring" extra)
# ----------------------------------------------------------------------------
HPM_SECRET_STORE=env
# HPM_SECRET_STORE_PATH=./.hermes_pm_data/secrets.enc
# HPM_SECRET_MASTER_PASSPHRASE=replace-with-a-strong-passphrase
HPM_SIGNING_KEY_NAME=live_signing_key

# Secrets are read as HPM_SECRET_<NAME> (uppercased). Example signing key for the
# env backend (placeholder only — never commit a real key):
# HPM_SECRET_LIVE_SIGNING_KEY=0xPLACEHOLDER_DO_NOT_USE_A_REAL_KEY

# ----------------------------------------------------------------------------
# Social / external signals (OFF by default; official X API only, no scraping).
# Without a key the system uses offline synthetic signals.
# ----------------------------------------------------------------------------
HPM_X_API_ENABLED=false
# HPM_X_API_BEARER_TOKEN=replace-with-your-x-api-bearer-token
